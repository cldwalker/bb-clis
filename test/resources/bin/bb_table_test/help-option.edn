{:out "Usage: bb-table [options]
Reads from stdin if no file is given

Options:
  -f, --file            Read edn from FILE instead of stdin
  -c, --columns-filter  Select columns by comma delimited substring matches or
                        numbers from -H
  -H, --print-headers   Print column headers and their counts across rows
  -n, --number-rows     Add a :number column with row numbers
  -s, --sort            Sort by column
  -r, --reverse-sort    Reverse sort by column
  -S, --style           Table style. One of :plain, :org, :unicode or
                        :github-markdown (default: :plain)
  -h, --help            Show this help
"
 :exit 0
 :err ""}
